DATABASE_URL="postgresql://user:password@localhost:5432/devconnect"
JWT_SECRET="change-me-to-a-long-random-string"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# توكن لقراءة GitHub API (عرض المشاريع والـ stats) — مهم جدًا على Render!
# من غيره الحد 60 طلب/ساعة للـ IP كله (بينفد فورًا على استضافة مشتركة)، بيه 5000/ساعة
# اعمله من github.com/settings/tokens → Fine-grained token → Public repos (read-only) ومن غير أي permissions إضافية
GITHUB_TOKEN=""
CLIENT_URL="http://localhost:5173"
PORT=4000

# رابط السيرفر نفسه (مهم لـ Google OAuth callback) — على Render حط رابط الخدمة
SERVER_URL="http://localhost:4000"

# Google OAuth (من console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SMTP لإيميلات استعادة الباسورد (اختياري — من غيره اللينك بيتطبع في الـ logs)
# مجاني من brevo.com: 300 إيميل/يوم
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="DevConnect <no-reply@yourdomain.com>"
