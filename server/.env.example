# اتصال التطبيق بالداتابيز. لو بتستخدم connection pooler (Neon/Supabase/PgBouncer)
# حط رابط الـ pooler هنا — ده اللي بيتحمل عدد الاتصالات الكبير.
DATABASE_URL="postgresql://user:password@localhost:5432/devconnect"

# اتصال مباشر من غير pooler — بيتستخدم في الميجريشنز بس (prisma migrate).
# PgBouncer في transaction mode بيكسر الـ advisory locks بتاعة prisma migrate،
# فالميجريشن ممكن تعلّق أو تفشل لو مشيت على الـ pooler.
#  - Neon: نفس رابط DATABASE_URL بالظبط بس امسح "-pooler" من اسم الهوست
#  - Postgres عادي من غير pooler: حط نفس قيمة DATABASE_URL
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/devconnect"

# لازم يكون 32 حرف على الأقل. ولّده بـ: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# توكن لقراءة GitHub API (عرض المشاريع والـ stats) — مهم جدًا على Render!
# من غيره الحد 60 طلب/ساعة للـ IP كله (بينفد فورًا على استضافة مشتركة)، بيه 5000/ساعة
# اعمله من github.com/settings/tokens → Fine-grained token → Public repos (read-only) ومن غير أي permissions إضافية
GITHUB_TOKEN=""
# الـ origins المسموح لها (CORS + Socket.io). ممكن أكتر من واحد بفاصلة:
#   CLIENT_URL="https://devconnect.app,https://www.devconnect.app"
# أول واحد هو الأساسي — بيتستخدم في redirects الـ OAuth وروابط الإيميلات.
# ⚠️ مطلوب في الإنتاج، والـ localhost مرفوض هناك (السيرفر مش هيقوم أصلاً).
CLIENT_URL="http://localhost:5173"
PORT=4000

# رابط السيرفر نفسه (مهم لـ Google OAuth callback) — لازم يطابق اللي مسجّل
# في Google Console بالحرف. ⚠️ مطلوب في الإنتاج، والـ localhost مرفوض هناك.
SERVER_URL="http://localhost:4000"

# عدد الـ reverse proxies الموثوقة قدام التطبيق — بيحدد إزاي بنعرف IP المستخدم
# الحقيقي، واللي الـ rate limiting كله متبني عليه.
# ⚠️ غلط هنا = تجاوز كامل للـ rate limit (brute force على الباسوردات).
#   false = التطبيق متعرض مباشرة من غير أي بروكسي
#   1     = بروكسي واحد بالظبط (nginx / Render / Railway)  ← الافتراضي في الإنتاج
#   2     = اتنين (مثلاً Cloudflare + nginx)
# عدّها صح: كل hop بيضيف IP في X-Forwarded-For.
TRUST_PROXY="false"

# Google OAuth (من console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# اسم حساب Cloudinary (نفس VITE_CLOUDINARY_CLOUD_NAME بتاع الـ client).
# الرفع بيحصل من المتصفح، والـ API بيتأكد إن روابط الصور/المرفقات المخزّنة
# بتشاور على حسابك ده مش على أي سيرفر تاني. لو سِبته فاضي، الفحص بيتأكد من
# مضيف res.cloudinary.com بس — اضبطه في الإنتاج عشان القيد يكمل (BUG-11).
CLOUDINARY_CLOUD_NAME=""

# SMTP لإيميلات استعادة الباسورد (اختياري — من غيره اللينك بيتطبع في الـ logs)
# مجاني من brevo.com: 300 إيميل/يوم
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="DevConnect <no-reply@yourdomain.com>"
