// DevConnect — Database Schema (Phase 1)
// المرحلة الأولى: Users + Profiles + Posts + Code Snippets
// الشات والـ Communities هيتضافوا في مراحل لاحقة على نفس الـ schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // التطبيق بيتكلم مع الداتابيز من خلال الـ pooler (PgBouncer) — ده اللي بيتحمل
  // عدد الاتصالات الكبير في الإنتاج
  url      = env("DATABASE_URL")
  // الميجريشنز لازم اتصال مباشر (من غير pooler): PgBouncer في transaction mode
  // بيكسر الـ advisory locks اللي prisma migrate بيعتمد عليها، وممكن يعلّق الـ deploy.
  // على Neon: نفس الرابط بالظبط بس من غير "-pooler" في اسم الهوست.
  directUrl = env("DIRECT_DATABASE_URL")
}

// ---------- Enums ----------

// ده أساس فلتر الـ HR: نوع الحساب بيتحدد من أول التسجيل
enum Role {
  DEVELOPER
  RECRUITER
}

enum Availability {
  OPEN_TO_WORK
  NOT_LOOKING
  FREELANCE_ONLY
}

enum PostType {
  TEXT
  SNIPPET
  PROJECT
  QUESTION
}

// ---------- Models ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String? // nullable عشان OAuth users
  githubId     String?  @unique
  googleId     String?  @unique
  // استعادة كلمة السر — بنخزن hash التوكن مش التوكن نفسه (أمان)
  resetTokenHash   String?
  resetTokenExpiry DateTime?
  // [SECURITY BUG-05] رقم إصدار الجلسات — بيتحط في الـ JWT وبيتقارن في كل طلب.
  // إعادة تعيين الباسورد بتزوّده، فأي توكن قديم (حتى لو مسروق) بيبطل فورًا.
  tokenVersion Int      @default(0)

  // [SECURITY BUG-06] حماية من الـ brute force على مستوى الحساب نفسه.
  // الـ rate limiting بتاع الـ IP لوحده مابيحميش من هجوم موزّع: مهاجم عنده
  // مئات الـ IPs بياخد من كل واحد نصيبه ويكمّل على نفس الحساب. الحالة دي
  // بتتخزن في الداتابيز عشان تعيش بعد أي restart أو deploy.
  failedLoginAttempts Int       @default(0)
  lastFailedLoginAt   DateTime?
  lockedUntil         DateTime?
  role         Role     @default(DEVELOPER)

  // صلاحية الإشراف — منفصلة عن role عن قصد. role نوع الحساب (مطوّر/recruiter)
  // وبيتبني عليه requireRole، فلو خلّينا ADMIN قيمة جواه يبقى الأدمن مش DEVELOPER
  // ولا RECRUITER وتتكسر الفحوصات دي. الأدمن هنا مطوّر أو recruiter + صلاحية زيادة.
  // بيتقرأ من الداتابيز في كل طلب (مش من الـ JWT) عشان سحب الصلاحية يسري فورًا.
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile  Profile?
  posts    Post[]
  conversations ConversationParticipant[]
  messages      Message[]
  communities   CommunityMember[]
  notifications Notification[]
  sentFriendRequests     Friendship[] @relation("SentFriendRequests")
  receivedFriendRequests Friendship[] @relation("ReceivedFriendRequests")
  following      Follow[] @relation("Following")
  followers      Follow[] @relation("Followers")
  blocksMade     Block[]  @relation("BlocksMade")
  blocksReceived Block[]  @relation("BlocksReceived")
  reportsMade     Report[] @relation("ReportsMade")
  reportsReviewed Report[] @relation("ReportsReviewed")
  refreshTokens   RefreshToken[]
  shortlistsMade ShortlistEntry[] @relation("ShortlistsMade")
  shortlistedAs  ShortlistEntry[] @relation("ShortlistedAs")
  jobsPosted     Job[]            @relation("JobsPosted")
  applications   Application[]    @relation("ApplicationsAsCandidate")
  comments Comment[]
  likes    Like[]
  reposts  Repost[]
  communityJoinRequests CommunityJoinRequest[]
}

// بيانات البروفايل — دي اللي فلتر الـ HR هيشتغل عليها
model Profile {
  id              String        @id @default(cuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String
  headline        String? // "Full Stack Architect & UI/UX Specialist"
  bio             String?
  avatarUrl       String?
  location        String?
  yearsExperience Int           @default(0)
  specialty       String? // "Frontend", "Backend", "DevOps", "AI/ML"...
  availability    Availability  @default(NOT_LOOKING)
  websiteUrl      String?
  githubUrl       String?
  githubUsername  String? // للـ GitHub projects import
  onboarded       Boolean       @default(false) // خلّص خطوات الترحيب؟
  // عداد مشاهدات البروفايل — بيزيد مع كل زيارة من مستخدم تاني (ويدجت الفيد)
  profileViews    Int           @default(0)
  bannerUrl       String? // صورة الغلاف (Cloudinary) — الديزاين الجديد
  // رابط الـ CV (PDF على Cloudinary) — بيظهر للـ recruiters وصاحب البروفايل بس
  resumeUrl       String?
  experiences     Experience[]
  // [SECURITY BUG-01] الظهور للـ recruiters بموافقة صريحة — الافتراضي مخفي.
  // من غيره أي حساب recruiter (والتسجيل مفتوح) كان يقدر يعدّد بيانات كل المطورين.
  // فلتر الـ talent search بيرجّع بس اللي discoverable=true.
  discoverable    Boolean       @default(false)
  skills          ProfileSkill[]

  @@index([specialty, yearsExperience, availability]) // فهرس مخصوص لفلتر الـ HR
  @@index([discoverable]) // فلتر الظهور بيتطبق على كل بحث talent
}

// الخبرات الوظيفية — الـ Career Roadmap في البروفايل وصفحة المرشح
model Experience {
  id          String  @id @default(cuid())
  profileId   String
  profile     Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String  // "Senior Frontend Engineer"
  company     String  // "TechFlow Systems"
  startYear   Int
  endYear     Int?    // null = Present
  description String?

  @@index([profileId, startYear])
}

model Skill {
  id       String         @id @default(cuid())
  name     String         @unique // "React", "TypeScript", "Docker"...
  profiles ProfileSkill[]
}

// جدول وسيط عشان علاقة many-to-many بين البروفايل والـ skills
model ProfileSkill {
  profileId String
  skillId   String
  years     Int    @default(0)
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([profileId, skillId])
  @@index([skillId])
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type      PostType @default(TEXT)
  title     String?
  body      String
  // بيانات الـ code snippet (لو النوع SNIPPET)
  codeLanguage String?
  codeContent  String?
  // snippet طالب مساعدة — بيعرض بادج "Help Wanted" زي السؤال (اختياري للـ SNIPPET)
  wantsHelp    Boolean @default(false)
  imageUrl     String? // صورة مرفقة بالبوست (Cloudinary)
  pinned       Boolean @default(false) // مثبّت فوق فيد الكوميونتي (أدمن بس)
  // البوست ممكن يكون في مجتمع (أو عادي في الـ feed لو null)
  communityId String?
  community   Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments Comment[]
  likes    Like[]
  reposts  Repost[]

  @@index([authorId, createdAt])
  @@index([type, createdAt])
  @@index([communityId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

enum ReactionType {
  LIKE
  LOVE
  SUPPORT
  CELEBRATE
  ANGRY
}

model Like {
  userId String
  postId String
  type   ReactionType @default(LIKE)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Repost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  comment   String? // نص الاقتباس (اختياري)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId]) // مستخدم واحد repost واحد بس لكل بوست (toggle زي اللايك)
  @@index([postId])
  @@index([userId, createdAt])
}

// ---------- Phase 4: Messaging ----------

model Conversation {
  id        String   @id @default(cuid())
  isGroup   Boolean  @default(false) // جروب ولا محادثة 1:1
  name      String?  // اسم الجروب (للجروبات بس)
  avatarUrl String?  // صورة الجروب
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // بنحدثه مع كل رسالة عشان نرتب القائمة بآخر نشاط

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  // الرسالة ممكن تكون code snippet — زي الـ mockup
  codeLanguage   String?
  codeContent    String?
  // مرفقات (صور وملفات على Cloudinary) — قسم Shared Media & Files في الديزاين
  attachmentUrl  String?
  attachmentType String? // "image" | "file"
  attachmentName String? // اسم الملف الأصلي للعرض
  attachmentSize Int?    // بالبايت
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ---------- Phase 6: Communities & Notifications ----------

enum CommunityRole {
  MEMBER
  ADMIN
}

enum NotificationType {
  POST_LIKE
  POST_COMMENT
  POST_REPOST
  COMMUNITY_JOIN
  COMMUNITY_ROLE     // ترقية/تنزيل أدمن
  COMMUNITY_REQUEST  // طلب انضمام جديد (للأدمن) أو قبول الطلب (للعضو)
  FRIEND_REQUEST
  FRIEND_ACCEPT
  NEW_FOLLOWER
}

model Community {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  category    String // "Frontend", "Backend", "AI & ML", "DevOps", "Mobile"...
  avatarUrl   String? // لوجو الكوميونتي (Cloudinary)
  coverUrl    String? // صورة الغلاف في كارت الـ Hub — الديزاين الجديد
  // وضع المدونة: لو true الأدمنّات بس اللي بينشروا
  adminOnlyPosting Boolean @default(false)
  // كوميونتي خاص: الانضمام بطلب وموافقة أدمن، والبوستات للأعضاء بس
  isPrivate Boolean @default(false)
  createdAt   DateTime @default(now())

  members      CommunityMember[]
  posts        Post[]
  joinRequests CommunityJoinRequest[]

  @@index([category])
}

// طلبات الانضمام للكوميونتيهات الخاصة — بتتمسح بعد القبول/الرفض
model CommunityJoinRequest {
  communityId String
  userId      String
  createdAt   DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([communityId, userId])
  @@index([userId])
}

model CommunityMember {
  communityId String
  userId      String
  role        CommunityRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([communityId, userId])
  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String // المستلم
  actorId   String? // اللي عمل الحدث (ممكن يكون null لإشعارات النظام)
  type      NotificationType
  message   String
  link      String? // رابط نسبي — مثلاً /feed أو /communities/react-masters
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

// ---------- Group 2: Friends, Follows, Groups, Moderation ----------

enum FriendStatus {
  PENDING   // اترسل طلب، مستني قبول
  ACCEPTED  // أصدقاء فعلاً
}

// الصداقة علاقة متبادلة — بنخزن صف واحد بس، requester + addressee
model Friendship {
  id          String       @id @default(cuid())
  requesterId String       // اللي بعت الطلب
  addresseeId String       // اللي استقبل الطلب
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())

  requester User @relation("SentFriendRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("ReceivedFriendRequests", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId]) // مايتكررش نفس الطلب
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

// المتابعة علاقة اتجاه واحد — follower بيتابع following
model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

// حظر — لو A حظر B، مايشوفش بعض ولا يتفاعلوا
model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
}

// بلاغات — مراجعة يدوية لاحقًا (بوست أو مستخدم)
// جلسة واحدة = جهاز واحد. الـ access token بقى عمره 15 دقيقة، والتوكن ده هو
// اللي بيجدّده. وجوده في الداتابيز هو اللي بيخلي تسجيل الخروج الحقيقي وإبطال
// جهاز بعينه ممكنين — الـ JWT لوحده مايتلغيش قبل ما يخلص.
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  // بنخزن SHA-256 مش التوكن نفسه — نفس منطق resetTokenHash: لو الداتابيز
  // اتسربت، اللي فيها مايفتحش جلسات. SHA-256 كفاية هنا (مش bcrypt) لأن
  // التوكن نفسه 32 بايت عشوائية، مفيش حاجة تتخمّن أو تتكسر بـ dictionary.
  tokenHash String   @unique
  // كل جهاز بياخد familyId ثابت، والدوران بينشئ صف جديد بنفس الـ id ده.
  // كشف إعادة الاستخدام بيبطّل العيلة كلها مرة واحدة.
  familyId  String
  expiresAt DateTime
  createdAt DateTime @default(now())
  // اتملى = التوكن ده اتصرف فيه خلاص. لو حد جه يستخدمه تاني بعد كده يبقى
  // نسخة مسروقة (أو عميل باظ) — والرد إن العيلة كلها تتقفل.
  rotatedAt DateTime?
  revokedAt DateTime?
  // للمستخدم يشوف "إيه الأجهزة الداخلة على حسابي" — مش لأي قرار أمني
  userAgent String?  @db.VarChar(300)
  ip        String?  @db.VarChar(64)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([familyId])
  // تنضيف الصفوف المنتهية
  @@index([expiresAt])
}

model Report {
  id             String   @id @default(cuid())
  reporterId     String
  reason         String
  targetPostId   String?  // بلاغ عن بوست
  targetUserId   String?  // أو بلاغ عن مستخدم
  createdAt      DateTime @default(now())

  // دورة حياة المراجعة. من غير الأعمدة دي البلاغات بتتكوّم من غير ما حد
  // يعرف اتعمل فيها إيه — وده كان الوضع فعلًا قبل كده.
  status         ReportStatus @default(PENDING)
  reviewedAt     DateTime?
  reviewedById   String?
  resolutionNote String?      @db.VarChar(1000) // ليه اتقفل البلاغ — للسجل الداخلي

  reporter User  @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  // SetNull مش Cascade: لو المشرف اتمسح حسابه، سجل المراجعة يفضل موجود
  reviewer User? @relation("ReportsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  // شاشة المراجعة بتفلتر بالحالة وترتّب بالأقدم — الفهرس ده بيخدم ده مباشرة
  @@index([status, createdAt])
}

// ملاحظة: targetPostId/targetUserId متسابين string مش foreign keys عن قصد.
// البلاغ سجل تاريخي: لو البوست اللي اتبلّغ عنه اتمسح، البلاغ لازم يفضل قابل
// للمراجعة (بيبان إن المحتوى اتمسح) بدل ما يختفي أو يمنع الحذف. الـ admin
// routes بتجيب الهدف بـ batch lookup.
enum ReportStatus {
  PENDING   // جديد، محدش بصّ عليه
  REVIEWING // مشرف ماسكه دلوقتي
  RESOLVED  // اتاخد فيه إجراء
  DISMISSED // اتراجع وطلع مفيش مخالفة
}

// ---------- Group 5: Jobs & Hiring Pipeline (الديزاين الجديد) ----------

enum JobStatus {
  OPEN
  CLOSED
}

// مراحل الـ pipeline — عمود Status في جدول الـ Talent Pool بالديزاين
enum ApplicationStage {
  SOURCED
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
}

model Job {
  id             String    @id @default(cuid())
  recruiterId    String
  recruiter      User      @relation("JobsPosted", fields: [recruiterId], references: [id], onDelete: Cascade)
  title          String // "Senior React Developer"
  description    String?
  location       String? // "Remote", "San Francisco, CA"...
  employmentType String? // "Full-time", "Contract"...
  skills         String[] // المهارات المطلوبة — الـ match score بيتحسب منها
  status         JobStatus @default(OPEN)
  createdAt      DateTime  @default(now())

  applications Application[]

  @@index([recruiterId, status])
}

// ربط مرشح بوظيفة + مرحلته في الـ pipeline
model Application {
  id          String           @id @default(cuid())
  jobId       String
  job         Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   User             @relation("ApplicationsAsCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  stage       ApplicationStage @default(SOURCED)
  note        String? // ملاحظة الـ recruiter على المرشح في الوظيفة دي
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([jobId, candidateId]) // المرشح مرة واحدة في كل وظيفة
  @@index([jobId, stage])
  @@index([candidateId])
}

// ---------- Group 4: Recruiter Shortlist ----------

model ShortlistEntry {
  id          String   @id @default(cuid())
  recruiterId String   // الـ HR اللي حفظ المرشح
  candidateId String   // المرشح المحفوظ
  note        String?  // ملاحظات الـ HR الخاصة
  createdAt   DateTime @default(now())

  recruiter User @relation("ShortlistsMade", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidate User @relation("ShortlistedAs", fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([recruiterId, candidateId]) // مايتكررش نفس المرشح عند نفس الـ HR
  @@index([recruiterId, createdAt])
}
