# رابط الـ backend على Render (بدون / في الآخر)
# ⚠️ لازم يطابق اسم سيرفس Render في render.yaml. لو اتغير الاسم هناك، لازم
# يتغير هنا **وفي متغيرات البيئة في لوحة Vercel كمان** — الملف ده مرجع بس،
# اللي بيتبني فعلاً هو اللي في اللوحة.
# في التطوير المحلي سيبه فاضي أو امسح السطر خالص — الـ Vite proxy هيتولى الأمر
VITE_API_URL="https://loopin-api.onrender.com"

# Cloudinary (رفع الصور) — من cloudinary.com (مجاني)
# اعمل unsigned upload preset من Settings → Upload
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""
